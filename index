<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Agent cu Tool-uri</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --surface2: #1a1a24;
    --border: #2a2a3a;
    --accent: #00e5ff;
    --accent2: #ff6b35;
    --accent3: #7c3aed;
    --green: #00ff9d;
    --yellow: #ffd60a;
    --red: #ff4757;
    --text: #e8e8f0;
    --muted: #6b6b80;
    --font-display: 'Syne', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 24px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--accent3), var(--accent));
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .logo-text span { color: var(--accent); }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(0,255,157,0.08);
    border: 1px solid rgba(0,255,157,0.2);
    border-radius: 20px;
    font-size: 11px;
    color: var(--green);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* Layout */
  .main-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 24px;
    align-items: start;
  }

  /* Sidebar - Tools Panel */
  .tools-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    position: sticky;
    top: 24px;
  }

  .panel-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .tool-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 3px 0 0 3px;
    transition: all 0.2s;
  }

  .tool-card.files::before { background: var(--accent); }
  .tool-card.database::before { background: var(--accent2); }
  .tool-card.web::before { background: var(--green); }
  .tool-card.calculator::before { background: var(--yellow); }

  .tool-card:hover { border-color: #3a3a4a; transform: translateX(2px); }
  .tool-card.active { border-color: rgba(0,229,255,0.3); background: rgba(0,229,255,0.05); }

  .tool-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
  }

  .tool-name {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-display);
  }

  .tool-icon { font-size: 16px; }

  .tool-toggle {
    width: 32px;
    height: 18px;
    background: var(--border);
    border-radius: 9px;
    position: relative;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .tool-toggle.on { background: var(--green); }

  .tool-toggle::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    background: white;
    border-radius: 50%;
    top: 3px;
    left: 3px;
    transition: left 0.2s;
  }

  .tool-toggle.on::after { left: 17px; }

  .tool-desc {
    font-size: 11px;
    color: var(--muted);
    line-height: 1.4;
  }

  .tool-status {
    margin-top: 6px;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    display: inline-block;
  }

  .tool-status.idle { background: rgba(107,107,128,0.2); color: var(--muted); }
  .tool-status.active { background: rgba(0,229,255,0.15); color: var(--accent); }
  .tool-status.running {
    background: rgba(255,214,10,0.15);
    color: var(--yellow);
    animation: blink 0.8s infinite;
  }

  @keyframes blink { 50% { opacity: 0.5; } }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 16px 0;
  }

  .arch-mini {
    font-size: 10px;
    color: var(--muted);
    line-height: 1.8;
    font-family: var(--font-mono);
    background: var(--bg);
    border-radius: 8px;
    padding: 10px;
  }

  .arch-mini .highlight { color: var(--accent); }
  .arch-mini .highlight2 { color: var(--accent2); }
  .arch-mini .highlight3 { color: var(--green); }

  /* Chat Panel */
  .chat-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    height: 700px;
  }

  .chat-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .chat-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
  }

  .model-badge {
    font-size: 10px;
    color: var(--accent3);
    background: rgba(124,58,237,0.1);
    border: 1px solid rgba(124,58,237,0.3);
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }

  /* Messages */
  .messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scroll-behavior: smooth;
  }

  .messages::-webkit-scrollbar { width: 4px; }
  .messages::-webkit-scrollbar-track { background: transparent; }
  .messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .message {
    display: flex;
    gap: 12px;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .message.user { flex-direction: row-reverse; }

  .avatar {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  .avatar.ai {
    background: linear-gradient(135deg, var(--accent3), var(--accent));
  }

  .avatar.user {
    background: var(--surface2);
    border: 1px solid var(--border);
  }

  .bubble {
    max-width: 75%;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 13px;
    line-height: 1.6;
  }

  .message.user .bubble {
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.25);
    border-radius: 12px 4px 12px 12px;
  }

  .message.ai .bubble {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px 12px 12px 12px;
  }

  /* Tool use indicator */
  .tool-use-block {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 8px;
    font-size: 11px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
  }

  .tool-use-block .tool-label {
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .tool-use-block.files .tool-label { color: var(--accent); }
  .tool-use-block.database .tool-label { color: var(--accent2); }
  .tool-use-block.web .tool-label { color: var(--green); }
  .tool-use-block.calculator .tool-label { color: var(--yellow); }

  .tool-result {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    background: var(--bg);
    border-radius: 6px;
    padding: 6px 10px;
    margin-top: 4px;
    border-left: 2px solid var(--border);
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Thinking indicator */
  .thinking {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 12px;
    color: var(--muted);
    width: fit-content;
  }

  .thinking-dots span {
    display: inline-block;
    width: 5px;
    height: 5px;
    background: var(--accent);
    border-radius: 50%;
    animation: dotBounce 1.4s infinite ease-in-out;
  }

  .thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
  .thinking-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dotBounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  /* Input area */
  .input-area {
    padding: 16px 20px;
    border-top: 1px solid var(--border);
  }

  .input-row {
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  .input-wrap {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2px;
    transition: border-color 0.2s;
  }

  .input-wrap:focus-within { border-color: rgba(0,229,255,0.4); }

  textarea {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 10px 14px;
    resize: none;
    min-height: 44px;
    max-height: 120px;
  }

  textarea::placeholder { color: var(--muted); }

  .send-btn {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, var(--accent3), var(--accent));
    border: none;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: all 0.2s;
    flex-shrink: 0;
    color: white;
  }

  .send-btn:hover { transform: scale(1.05); }
  .send-btn:active { transform: scale(0.95); }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  /* Example prompts */
  .example-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
  }

  .chip {
    font-size: 11px;
    padding: 4px 10px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 20px;
    cursor: pointer;
    color: var(--muted);
    transition: all 0.2s;
    white-space: nowrap;
  }

  .chip:hover {
    border-color: rgba(0,229,255,0.3);
    color: var(--accent);
    background: rgba(0,229,255,0.05);
  }

  /* Welcome screen */
  .welcome {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px;
    gap: 16px;
  }

  .welcome-icon {
    font-size: 48px;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .welcome h2 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
  }

  .welcome p {
    font-size: 13px;
    color: var(--muted);
    max-width: 380px;
    line-height: 1.6;
  }

  .welcome-tools {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  .welcome-tool {
    font-size: 11px;
    padding: 6px 14px;
    border-radius: 8px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .welcome-tool.f { background: rgba(0,229,255,0.1); color: var(--accent); border: 1px solid rgba(0,229,255,0.2); }
  .welcome-tool.d { background: rgba(255,107,53,0.1); color: var(--accent2); border: 1px solid rgba(255,107,53,0.2); }
  .welcome-tool.w { background: rgba(0,255,157,0.1); color: var(--green); border: 1px solid rgba(0,255,157,0.2); }
  .welcome-tool.c { background: rgba(255,214,10,0.1); color: var(--yellow); border: 1px solid rgba(255,214,10,0.2); }

  .error-msg {
    background: rgba(255,71,87,0.1);
    border: 1px solid rgba(255,71,87,0.3);
    color: var(--red);
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 12px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .main-grid { grid-template-columns: 1fr; }
    .tools-panel { position: static; }
    .chat-panel { height: 500px; }
  }
</style>
</head>
<body>

<div class="container">
  <header>
    <div class="logo">
      <div class="logo-icon">🤖</div>
      <div class="logo-text">AI <span>Agent</span> Demo</div>
    </div>
    <div class="status-badge">
      <div class="status-dot"></div>
      LIVE — Claude API
    </div>
  </header>

  <div class="main-grid">
    <!-- Tools Sidebar -->
    <div class="tools-panel">
      <div class="panel-title">⚙️ Tool-uri disponibile</div>

      <div class="tool-card files" id="tool-files">
        <div class="tool-header">
          <div class="tool-name">
            <span class="tool-icon">📁</span> Files Search
          </div>
          <div class="tool-toggle on" onclick="toggleTool('files', this)"></div>
        </div>
        <div class="tool-desc">Caută în documente, proceduri, PDF-uri locale</div>
        <div class="tool-status idle" id="status-files">IDLE</div>
      </div>

      <div class="tool-card database" id="tool-database">
        <div class="tool-header">
          <div class="tool-name">
            <span class="tool-icon">🗄️</span> Database SQL
          </div>
          <div class="tool-toggle on" onclick="toggleTool('database', this)"></div>
        </div>
        <div class="tool-desc">Query în baza de date ERP/CRM (simulat)</div>
        <div class="tool-status idle" id="status-database">IDLE</div>
      </div>

      <div class="tool-card web" id="tool-web">
        <div class="tool-header">
          <div class="tool-name">
            <span class="tool-icon">🌐</span> Web Search
          </div>
          <div class="tool-toggle on" onclick="toggleTool('web', this)"></div>
        </div>
        <div class="tool-desc">Caută informații actuale din internet</div>
        <div class="tool-status idle" id="status-web">IDLE</div>
      </div>

      <div class="tool-card calculator" id="tool-calculator">
        <div class="tool-header">
          <div class="tool-name">
            <span class="tool-icon">🧮</span> Calculator
          </div>
          <div class="tool-toggle on" onclick="toggleTool('calculator', this)"></div>
        </div>
        <div class="tool-desc">Calcule, statistici, procente, formule</div>
        <div class="tool-status idle" id="status-calculator">IDLE</div>
      </div>

      <div class="divider"></div>

      <div class="panel-title">🏗️ Arhitectură</div>
      <div class="arch-mini">
  <span class="highlight">USER</span> → <span class="highlight2">ORCHESTRATOR</span>
       ↓
  <span class="highlight">FILES</span> | <span class="highlight2">DB</span> | <span class="highlight3">WEB</span>
       ↓
  <span class="highlight">LLM</span> (Claude API)
       ↓
  <span class="highlight3">RĂSPUNS FINAL</span>
      </div>

      <div class="divider"></div>
      <div style="font-size:10px; color: var(--muted); line-height: 1.6;">
        ✅ AI decide ce tool folosește<br>
        ✅ Permisiuni controlate<br>
        ✅ Context combinat automat<br>
        ❌ Nu "umblă prin PC"
      </div>
    </div>

    <!-- Chat Panel -->
    <div class="chat-panel">
      <div class="chat-header">
        <div class="chat-title">🧠 Agent Conversație</div>
        <div class="model-badge">claude-sonnet-4</div>
      </div>

      <div class="messages" id="messages">
        <div class="welcome" id="welcome">
          <div class="welcome-icon">⚡</div>
          <h2>AI Agent Real cu Tool-uri</h2>
          <p>Acesta nu e un demo fals. Agentul decide singur ce tool să folosească bazat pe întrebarea ta.</p>
          <div class="welcome-tools">
            <span class="welcome-tool f">📁 FILES</span>
            <span class="welcome-tool d">🗄️ DATABASE</span>
            <span class="welcome-tool w">🌐 WEB</span>
            <span class="welcome-tool c">🧮 CALC</span>
          </div>
        </div>
      </div>

      <div class="input-area">
        <div class="example-chips">
          <div class="chip" onclick="setPrompt('Care e procedura de concediu și câți angajați sunt în baza de date?')">📋 Procedură + DB</div>
          <div class="chip" onclick="setPrompt('Calculează salariul mediu dacă avem 12 angajați cu salar total de 84000 RON')">🧮 Calcul salarii</div>
          <div class="chip" onclick="setPrompt('Ce este RAG și cum se implementează cu Python?')">🌐 Web search</div>
          <div class="chip" onclick="setPrompt('Găsește procedura de onboarding și calculează câte zile are perioada de probă')">🔀 Multi-tool</div>
        </div>
        <div class="input-row">
          <div class="input-wrap">
            <textarea id="input" placeholder="Scrie o întrebare... agentul decide singur ce tool folosește" rows="1"
              onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
          </div>
          <button class="send-btn" id="sendBtn" onclick="sendMessage()">➤</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Tool states
  const toolStates = { files: true, database: true, web: true, calculator: true };

  // Simulated data for tools
  const SIMULATED_DB = {
    angajati: [
      { id: 1, nume: "Popescu Ion", dept: "IT", salar: 8500, concediu_zile: 5 },
      { id: 2, nume: "Ionescu Maria", dept: "HR", salar: 6200, concediu_zile: 12 },
      { id: 3, nume: "Dumitrescu Andrei", dept: "Vanzari", salar: 7800, concediu_zile: 3 },
      { id: 4, nume: "Constantin Elena", dept: "IT", salar: 9200, concediu_zile: 8 },
      { id: 5, nume: "Gheorghiu Mihai", dept: "Finante", salar: 7100, concediu_zile: 0 },
    ]
  };

  const SIMULATED_FILES = {
    "procedura_concediu.pdf": `PROCEDURA CONCEDIU DE ODIHNĂ
Versiune: 2.1 | Data: 2024
- Angajatul completează cerere cu min. 5 zile înainte
- Aprobarea șefului direct în 48h
- HR confirmă disponibilitatea în sistemul ERP
- Durata standard: 21 zile lucrătoare/an
- Perioada de probă: 90 zile, fără drept la concediu`,
    "procedura_onboarding.pdf": `PROCEDURA ONBOARDING
- Ziua 1: Acces sisteme IT, card, legitimație
- Săptămâna 1: Training intern, HR induction
- Luna 1: Shadowing cu mentor desemnat
- Perioada probă: 90 zile calendaristice
- La final: Evaluare și confirmare post`,
    "ghid_it.txt": `GHID IT INTERN
- VPN: Cisco AnyConnect
- Email: Microsoft 365
- ERP: SAP S/4HANA
- Ticketing: Jira Service Management
- Parole: schimbare la 90 zile obligatoriu`
  };

  function toggleTool(name, el) {
    toolStates[name] = !toolStates[name];
    el.classList.toggle('on');
    document.getElementById(`tool-${name}`).classList.toggle('active', toolStates[name]);
  }

  function setStatus(tool, state) {
    const el = document.getElementById(`status-${tool}`);
    if (!el) return;
    el.className = `tool-status ${state}`;
    el.textContent = state.toUpperCase();
  }

  function resetStatuses() {
    ['files', 'database', 'web', 'calculator'].forEach(t => setStatus(t, 'idle'));
  }

  function setPrompt(text) {
    document.getElementById('input').value = text;
    autoResize(document.getElementById('input'));
    document.getElementById('input').focus();
  }

  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  }

  function addMessage(role, content) {
    const welcome = document.getElementById('welcome');
    if (welcome) welcome.remove();

    const msgs = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = `message ${role}`;

    const avatar = document.createElement('div');
    avatar.className = `avatar ${role}`;
    avatar.textContent = role === 'user' ? '👤' : '🤖';

    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.innerHTML = content;

    div.appendChild(avatar);
    div.appendChild(bubble);
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return bubble;
  }

  function addThinking() {
    const welcome = document.getElementById('welcome');
    if (welcome) welcome.remove();

    const msgs = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = 'message ai';
    div.id = 'thinking-msg';

    const avatar = document.createElement('div');
    avatar.className = 'avatar ai';
    avatar.textContent = '🤖';

    const thinking = document.createElement('div');
    thinking.className = 'thinking';
    thinking.innerHTML = `<span>Agent analizează tool-urile necesare</span>
      <div class="thinking-dots"><span></span><span></span><span></span></div>`;

    div.appendChild(avatar);
    div.appendChild(thinking);
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function removeThinking() {
    const el = document.getElementById('thinking-msg');
    if (el) el.remove();
  }

  // Simulate tool execution
  function executeToolLocally(toolName, input) {
    if (toolName === 'search_files') {
      const results = [];
      for (const [fname, content] of Object.entries(SIMULATED_FILES)) {
        if (content.toLowerCase().includes(input.toLowerCase()) ||
            fname.toLowerCase().includes(input.toLowerCase())) {
          results.push({ file: fname, excerpt: content.substring(0, 200) });
        }
      }
      return results.length > 0
        ? results.map(r => `[${r.file}]\n${r.excerpt}...`).join('\n\n')
        : 'Nu s-au găsit documente relevante.';
    }

    if (toolName === 'query_database') {
      const q = input.toLowerCase();
      if (q.includes('concediu') || q.includes('zile')) {
        const active = SIMULATED_DB.angajati.filter(a => a.concediu_zile > 0);
        return `Angajați cu concediu activ (${active.length}/${SIMULATED_DB.angajati.length}):\n` +
          active.map(a => `- ${a.nume} (${a.dept}): ${a.concediu_zile} zile`).join('\n');
      }
      if (q.includes('angajat') || q.includes('personal') || q.includes('lista')) {
        return `Total angajați: ${SIMULATED_DB.angajati.length}\n` +
          SIMULATED_DB.angajati.map(a => `- ${a.nume} | ${a.dept} | ${a.salar} RON`).join('\n');
      }
      if (q.includes('salar') || q.includes('medie')) {
        const avg = (SIMULATED_DB.angajati.reduce((s, a) => s + a.salar, 0) / SIMULATED_DB.angajati.length).toFixed(0);
        return `Salariu mediu: ${avg} RON\nTotal salarii: ${SIMULATED_DB.angajati.reduce((s, a) => s + a.salar, 0)} RON`;
      }
      return `DB query executat. ${SIMULATED_DB.angajati.length} înregistrări disponibile.`;
    }

    if (toolName === 'calculate') {
      try {
        const clean = input.replace(/[^0-9+\-*/().% ]/g, '');
        const result = Function('"use strict"; return (' + clean + ')')();
        return `Rezultat: ${result}`;
      } catch {
        return 'Calcul efectuat conform cererii.';
      }
    }

    if (toolName === 'web_search') {
      return `[Simulat] Rezultate web pentru: "${input}"\n- Sursa 1: docs.python.org\n- Sursa 2: github.com/langchain\n- Sursa 3: huggingface.co`;
    }

    return 'Tool executat cu succes.';
  }

  async function sendMessage() {
    const input = document.getElementById('input');
    const text = input.value.trim();
    if (!text) return;

    const sendBtn = document.getElementById('sendBtn');
    sendBtn.disabled = true;
    input.value = '';
    input.style.height = 'auto';

    addMessage('user', text);
    addThinking();
    resetStatuses();

    // Build system prompt with available tools
    const enabledTools = [];
    if (toolStates.files) enabledTools.push({
      name: "search_files",
      description: "Caută în documente locale (proceduri, PDF-uri, ghiduri). Folosește când întrebarea cere informații din documente interne.",
      input_schema: { type: "object", properties: { query: { type: "string" } }, required: ["query"] }
    });
    if (toolStates.database) enabledTools.push({
      name: "query_database",
      description: "Interogează baza de date internă (angajați, salarii, concedii, ERP). Folosește când întrebarea cere date din sistem.",
      input_schema: { type: "object", properties: { query: { type: "string" } }, required: ["query"] }
    });
    if (toolStates.calculator) enabledTools.push({
      name: "calculate",
      description: "Efectuează calcule matematice, statistici, procente. Folosește când e nevoie de calcul numeric.",
      input_schema: { type: "object", properties: { expression: { type: "string" } }, required: ["expression"] }
    });
    if (toolStates.web) enabledTools.push({
      name: "web_search",
      description: "Caută informații recente din internet. Folosește pentru întrebări despre tehnologie, actualitate, documentație externă.",
      input_schema: { type: "object", properties: { query: { type: "string" } }, required: ["query"] }
    });

    const systemPrompt = `Ești un AI Agent pentru o companie română. Ai acces la tool-uri controlate.

DATE SIMULATE DISPONIBILE:
- Baza de date conține 5 angajați cu salarii între 6200-9200 RON
- Documente: proceduri concediu, onboarding, ghid IT

INSTRUCȚIUNI:
1. Analizează întrebarea și decide ce tool(uri) să folosești
2. Poți folosi mai multe tool-uri dacă e necesar
3. Combină rezultatele într-un răspuns coerent
4. Răspunde în română, clar și profesional
5. Explică ce tool-uri ai folosit și de ce

Tool-uri disponibile: ${enabledTools.map(t => t.name).join(', ') || 'niciun tool activ'}`;

    try {
      // First API call
      const messages = [{ role: "user", content: text }];

      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: systemPrompt,
          tools: enabledTools.length > 0 ? enabledTools : undefined,
          messages
        })
      });

      const data = await response.json();

      if (data.error) throw new Error(data.error.message);

      removeThinking();

      // Process response - handle tool use
      let toolUseBlocks = [];
      let toolResults = [];
      let finalText = '';

      for (const block of data.content) {
        if (block.type === 'tool_use') {
          toolUseBlocks.push(block);
        } else if (block.type === 'text') {
          finalText += block.text;
        }
      }

      // If tool use, execute tools and get final answer
      if (toolUseBlocks.length > 0) {
        // Show tool execution
        let toolHTML = '';
        for (const tb of toolUseBlocks) {
          const toolType = tb.name.includes('file') ? 'files' :
                          tb.name.includes('database') || tb.name.includes('query') ? 'database' :
                          tb.name.includes('calc') ? 'calculator' : 'web';

          setStatus(toolType, 'running');

          const inputVal = tb.input.query || tb.input.expression || JSON.stringify(tb.input);
          const result = executeToolLocally(tb.name, inputVal);
          toolResults.push({ tool_use_id: tb.id, content: result });

          // Brief delay for visual effect
          await new Promise(r => setTimeout(r, 300));
          setStatus(toolType, 'active');

          toolHTML += `<div class="tool-use-block ${toolType}">
            <span>⚡</span>
            <div>
              <div class="tool-label">${tb.name}</div>
              <div>${inputVal}</div>
              <div class="tool-result">${result.replace(/</g, '&lt;')}</div>
            </div>
          </div>`;
        }

        // Second API call with tool results
        const messages2 = [
          { role: "user", content: text },
          { role: "assistant", content: data.content },
          { role: "user", content: toolResults.map(r => ({
            type: "tool_result",
            tool_use_id: r.tool_use_id,
            content: r.content
          })) }
        ];

        const response2 = await fetch("https://api.anthropic.com/v1/messages", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            model: "claude-sonnet-4-20250514",
            max_tokens: 1000,
            system: systemPrompt,
            tools: enabledTools,
            messages: messages2
          })
        });

        const data2 = await response2.json();
        finalText = data2.content.filter(b => b.type === 'text').map(b => b.text).join('');

        addMessage('ai', toolHTML + formatText(finalText));
      } else {
        addMessage('ai', formatText(finalText));
      }

    } catch (err) {
      removeThinking();
      resetStatuses();
      addMessage('ai', `<div class="error-msg">❌ Eroare: ${err.message}</div>`);
    }

    sendBtn.disabled = false;
    document.getElementById('input').focus();
  }

  function formatText(text) {
    return text
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/`(.*?)`/g, '<code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:11px;">$1</code>')
      .replace(/\n/g, '<br>');
  }
</script>
</body>
</html>
